# What this file is: a template for the frontend's optional .env file.
# VITE_PROXY_URL isn't a secret -- it's just where to find the Worker proxy.
# Defaults to http://localhost:8787 if unset.
# In plain terms: shows you how to point the app at a different proxy URL
# than the default local one, if you ever need to.

VITE_PROXY_URL=http://localhost:8787
