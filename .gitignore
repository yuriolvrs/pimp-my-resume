# What this file is: tells Git which files/folders to never track
# (dependencies, build output, secrets, editor files).
# In plain terms: a list of files Git should ignore and never save.

# dependencies
node_modules/

# build output
dist/
dist-ssr/
*.tsbuildinfo

# secrets / local env — never commit (CLAUDE.md guardrail)
.env
.env.*
.dev.vars
*.local

# logs
*.log
npm-debug.log*

# editor / OS
.DS_Store
.vscode/*
!.vscode/extensions.json
.idea/
